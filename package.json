{
  "name": "travel-planner-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "description": "A TypeScript travel planning assistant agent built with LangChain and OpenAI.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:cli": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:native": "tsgo -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:native": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/static": "^8.2.0",
    "@langchain/core": "^0.3.28",
    "@langchain/langgraph": "^0.4.9",
    "@langchain/langgraph-checkpoint-postgres": "^0.1.2",
    "@langchain/openai": "^0.4.5",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.3",
    "pg": "^8.16.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "@typescript/native-preview": "^7.0.0-dev.20250906.1",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
